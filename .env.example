# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (error monitoring — server + client; optional in local dev)
# Create project: https://sentry.io — use the same DSN for both vars below
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Build-time only (Vercel / CI): upload source maps for readable stack traces
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Database (PostgreSQL + Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/creatornivo"
# Direct connection for pg_dump backups only (Supabase: not the pooler URL)
# BACKUP_DATABASE_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Off-site encrypted backups (GitHub Actions + local scripts/backup)
# BACKUP_AGE_PUBLIC_KEY="age1..."
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="creatornivo-db-backups"
# BACKUP_RETENTION_DAYS="30"
# RESTORE_DATABASE_URL="postgresql://postgres:password@127.0.0.1:5433/postgres"

# Email (password reset) — required in production for forgot-password flow
# Without RESEND_API_KEY: reset links are not emailed (dev logs emailHash only; prod falls back to support contact)
RESEND_API_KEY=""
# Verified sender/domain in Resend; must match your production domain
EMAIL_FROM="Creatornivo <noreply@creatornivo.com>"

# Auth rate limiting (Upstash Redis) — required in production
# Protects login, register, forgot-password (IP + emailHash), reset-password (IP)
# Without Upstash: limits are skipped (dev warns once; production should always configure)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Auth.js (NextAuth v5) — обязательно для работы авторизации
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Canonical app URL — used for password reset links and Auth.js callbacks
AUTH_URL="http://localhost:3000"

# Для NextAuth v5 также используется NEXTAUTH_URL (опционально, fallback for AUTH_URL)
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (optional)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# AI providers
OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Admin access (optional — альтернатива роли admin в БД)
# ADMIN_EMAILS="admin@example.com,owner@example.com"

# Paddle (Pro subscription — preferred)
# Sandbox: https://sandbox-vendors.paddle.com
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="test_..."
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox"
PADDLE_API_KEY="pdl_sdbx_apikey_..."
PADDLE_WEBHOOK_SECRET="pdl_ntfset_..."
# Price IDs from Paddle Dashboard → Catalog → Pro
PADDLE_PRO_PRICE_ID="pri_..."
# Early Access price ($4.9/mo) for first 50 users
PADDLE_EARLY_ACCESS_PRICE_ID="pri_..."

# Stripe (legacy fallback — optional if Paddle is configured)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_EARLY_ACCESS_PRICE_ID="price_..."