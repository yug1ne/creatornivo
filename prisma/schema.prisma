generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
}

enum Role {
  user
  admin
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  incomplete
  trialing
  unpaid
}

enum PaymentProvider {
  stripe
  paddle
}

enum TemplateCategory {
  x_thread
  linkedin_post
  newsletter
  instagram_post
  blog
  email
  marketing
  product
  youtube
  seo
  other
  facebook_post
  threads_post
  pinterest
  reddit
  google_business
  tiktok
  ecommerce
  community
  product_launch
  sales
  app_ux
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  plan                  Plan                   @default(free)
  role                  Role                   @default(user)
  accounts              Account[]
  sessions              Session[]
  savedPrompts          SavedPrompt[]
  generations           Generation[]
  paddleCheckoutIntents PaddleCheckoutIntent[]
  paddleAdjustments     PaddleAdjustment[]
  subscription          Subscription?
  onboardingCompletedAt DateTime?
  welcomeEmailSentAt          DateTime?
  proConfirmationEmailSentAt  DateTime?
  passwordChangedAt           DateTime?
  passwordResetTokens   PasswordResetToken[]
  userUsage             UserUsage[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model UserUsage {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // UTC period start: day boundary (Free) or month boundary (Pro)
  count                      Int       @default(0)
  period                     String    // "daily" | "monthly"
  quotaExhaustedEmailSentAt  DateTime?
  quotaWarningEmailSentAt    DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, period])
  @@index([userId, period])
}

model AccountDeletionRequest {
  id            String    @id @default(cuid())
  userId        String
  emailHash     String
  status        String
  blockReason   String?
  failureReason String?
  requestedAt   DateTime  @default(now())
  completedAt   DateTime?
  ipHash        String?

  @@index([userId, requestedAt])
  @@index([emailHash, requestedAt])
  @@index([status, requestedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([tokenHash])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             PaymentProvider    @default(paddle)
  paddleCustomerId     String?            @unique
  paddleSubscriptionId String?            @unique
  paddlePriceId        String?
  paddleStatus         String?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(incomplete)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  lastPaddleEventAt    DateTime?
  earlyAccessClaimedAt DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([paddlePriceId, earlyAccessClaimedAt])
}

model PaddleWebhookEvent {
  eventId     String   @id
  eventType   String
  occurredAt  DateTime
  processedAt DateTime @default(now())

  @@index([occurredAt])
}

model PaddleCheckoutIntent {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceId              String
  paddleTransactionId  String?   @unique
  paddleSubscriptionId String?   @unique
  status               String    @default("pending")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  expiresAt            DateTime
  completedAt          DateTime?

  @@index([userId, createdAt])
  @@index([status, expiresAt])
}

model PaddleAdjustment {
  id                      String    @id @default(cuid())
  paddleAdjustmentId      String    @unique
  paddleTransactionId     String
  paddleSubscriptionId    String?
  userId                  String?
  user                    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action                  String
  type                    String?
  status                  String
  currencyCode            String?
  total                   String?
  occurredAt              DateTime
  processedAt             DateTime?
  accessAction            String    @default("none")
  accessRevokedAt         DateTime?
  accessRevokedReason     String?
  cancellationRequired    Boolean   @default(false)
  cancellationAttemptedAt DateTime?
  cancellationCompletedAt DateTime?
  lastEventId             String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([paddleTransactionId])
  @@index([paddleSubscriptionId])
  @@index([userId, occurredAt])
  @@index([cancellationRequired, cancellationCompletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Template {
  id           String           @id @default(cuid())
  slug         String           @unique
  title        String
  description  String
  category     TemplateCategory
  prompt       String           @db.Text
  variables    Json             @default("[]")
  requiredPlan Plan             @default(free)
  isActive     Boolean          @default(true)
  savedPrompts SavedPrompt[]
  generations  Generation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Generation {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  prompt     String    @db.Text
  result     String    @db.Text
  model      String
  tokensUsed Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model GenerationReservation {
  id                       String    @id @default(cuid())
  requestId                String
  userId                   String
  plan                     Plan
  periodKey                String
  status                   String    @default("reserved")
  model                    String
  estimatedMaxOutputTokens Int
  actualInputTokens        Int?
  actualOutputTokens       Int?
  createdAt                DateTime  @default(now())
  startedAt                DateTime?
  completedAt              DateTime?
  expiresAt                DateTime

  @@unique([userId, requestId])
  @@index([userId, periodKey])
  @@index([userId, createdAt])
  @@index([userId, status, expiresAt])
}

model SavedPrompt {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title      String
  content    String    @db.Text
  tags       String[]  @default([])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}
